{
  "name": "edumaster-qa-automation",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "android:web": "tsx src/runner.ts",
    "browser:auth-mobile": "node --import tsx src/auth-mobile-review.ts",
    "android:courses": "tsx src/courses-regression.ts",
    "browser:courses": "node --import tsx src/courses-browser-review.ts",
    "browser:live": "node --import tsx src/live-browser-review.ts",
    "browser:live-cert": "node --import tsx src/live-feature-certification.ts",
    "browser:live-join": "node --import tsx src/live-join-smoke.ts",
    "browser:live-recording": "node --import tsx src/live-recording-review.ts",
    "browser:overview": "node --import tsx src/overview-figma-review.ts",
    "load:platform": "node --import tsx src/platform-1000-load-review.ts",
    "load:live": "node --import tsx src/live-load-review.ts",
    "load:course-video": "node --import tsx src/course-video-1000-load-review.ts",
    "monitor:course-video": "node --import tsx src/course-video-continuous-monitor.ts",
    "monitor:course-video:light": "QA_MONITOR_MODE=continuous-light node --import tsx src/course-video-continuous-monitor.ts",
    "monitor:course-video:full": "QA_MONITOR_MODE=continuous-full node --import tsx src/course-video-continuous-monitor.ts",
    "qa:course-video:matrix": "PLAYBACK_QA_SKIP_LOAD=true node --import tsx src/course-video-production-qa.ts",
    "qa:course-video:production": "node --import tsx src/course-video-production-qa.ts",
    "load:recorded-browser": "node --import tsx src/recorded-browser-load-review.ts",
    "browser:tests": "node --import tsx src/tests-browser-review.ts",
    "loop": "tsx src/loop.ts",
    "generate:flutter": "tsx src/flutter-generator.ts"
  },
  "dependencies": {
    "appium": "^2.19.0",
    "appium-uiautomator2-driver": "^4.2.9",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.55.0",
    "pngjs": "^7.0.0",
    "puppeteer-core": "^24.23.1",
    "webdriverio": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2"
  }
}
