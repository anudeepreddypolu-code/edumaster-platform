{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "db:local:start": "./scripts/ensure-local-postgres.sh",
    "dev": "./scripts/ensure-local-postgres.sh && npm run dev:app",
    "dev:app": "tsx server.ts",
    "dev:local": "npm run dev",
    "start": "NODE_ENV=production tsx server.ts",
    "build": "vite build",
    "build:mobile:web": "vite build --mode production",
    "build:firebase": "vite build",
    "mobile:sync": "npm run build:mobile:web && ./node_modules/.bin/cap sync",
    "mobile:android": "npm run mobile:sync && ./node_modules/.bin/cap open android",
    "mobile:ios": "npm run mobile:sync && ./node_modules/.bin/cap open ios",
    "mobile:apk": "npm run mobile:sync && ./android/gradlew assembleDebug",
    "mobile:aab": "npm run mobile:sync && ./android/gradlew -p android bundleRelease",
    "deploy:firebase": "./deploy-quick.sh",
    "track:worker": "node backend/workers/watch-aggregator.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "validate:production": "node scripts/validate-production-config.cjs"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@google/genai": "^1.29.0",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "hls.js": "^1.6.15",
    "livekit-client": "^2.18.7",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "typeorm": "^0.3.28",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.15",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
