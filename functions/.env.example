NODE_ENV=production
FUNCTION_REGION=asia-south1
APP_URL=https://YOUR_PROJECT_ID.web.app
CORS_ORIGIN=https://YOUR_PROJECT_ID.web.app
SERVICE_NAME=edumaster-platform
ENVIRONMENT_LABEL=production
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
JSON_BODY_LIMIT=1mb

JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
PRIVATE_VIDEO_TOKEN_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
PRIVATE_VIDEO_TOKEN_TTL_SECONDS=900
PRIVATE_VIDEO_DELIVERY_URL_TTL_SECONDS=900
PRIVATE_VIDEO_DRM_ENABLED=false

POSTGRES_URL=
MONGODB_URI=
FIREBASE_STATE_STORAGE=false
FIREBASE_STATE_DATABASE_ID=
FIREBASE_STATE_COLLECTION=app_state
FIREBASE_STATE_DOCUMENT=primary
ALLOW_MEMORY_FALLBACK=false
AUTO_SEED_DEMO_DATA=false
ENABLE_DEV_SEED_ROUTES=false
EXPOSE_SAMPLE_CREDENTIALS=false

ADMIN_NAME=EduMaster Admin
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
AI_PROVIDER=auto
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

JITSI_MEET_DOMAIN=meet.jit.si
LIVE_HLS_INTERNAL_BASE_URL=
LIVE_INGEST_STREAM_BASE_URL=
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_ROOM_PREFIX=edumaster-live
LIVEKIT_TOKEN_TTL_SECONDS=600

PRIVATE_VIDEO_STORAGE_PROVIDER=local
ENABLE_VIDEO_TRANSCODING=true
SOURCE_PLAYBACK_FALLBACK_ENABLED=true
VIDEO_DELIVERY_PROFILE=cost-saver-hls
VIDEO_TARGET_RENDITIONS=480p,720p
VIDEO_HLS_SEGMENT_DURATION_SECONDS=6
VIDEO_KEEP_SOURCE_AFTER_PROCESSING=false
MAX_VIDEO_UPLOAD_MB=2048
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
YOUTUBE_UPLOAD_REFRESH_TOKEN=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
TRUST_PROXY=true
