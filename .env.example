# Root app server
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000
APP_DOMAIN=app.example.com
LIVE_DOMAIN=live.example.com
VITE_PUBLIC_APP_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:3000/backend/api
DISABLE_HMR=false
NODE_ENV=development
SERVICE_NAME=edumaster-platform
ENVIRONMENT_LABEL=local
JITSI_MEET_DOMAIN=meet.jit.si
LIVE_HLS_INTERNAL_BASE_URL=http://mediamtx:8888/hls
LIVE_INGEST_STREAM_BASE_URL=rtmp://live.example.com:1935/live
LIVE_INGEST_PUBLISHER_SECRET=replace_with_shared_ingest_secret
VITE_LIVE_HLS_BASE_URL=https://live.example.com/hls
VITE_LIVE_INGEST_RTMP_URL=rtmp://live.example.com:1935/live
VITE_LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_URL=wss://your-livekit-host
LIVEKIT_API_KEY=replace_me
LIVEKIT_API_SECRET=replace_me
LIVEKIT_ROOM_PREFIX=edumaster-live
LIVEKIT_TOKEN_TTL_SECONDS=600
LIVE_RECORDING_SWEEP_INTERVAL_MS=3600000
TRUST_PROXY=true
LOG_LEVEL=info
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
CORS_ORIGIN=*,http://localhost,capacitor://localhost,ionic://localhost

# Admin account
ADMIN_NAME=EduMaster Admin
ADMIN_EMAIL=admin@local.edumaster
ADMIN_PASSWORD=ChangeMeForLocalDev_2026

# Payments
STRIPE_SECRET_KEY=sk_test_replace_me
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
PHONEPE_ENV=sandbox
PHONEPE_CLIENT_ID=replace_me
PHONEPE_CLIENT_SECRET=replace_me
PHONEPE_CLIENT_VERSION=1
# Optional overrides if PhonePe gives you environment-specific hosts.
PHONEPE_API_BASE_URL=
PHONEPE_AUTH_BASE_URL=

# AI Studio / Gemini
GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.0-flash-lite

# Optional generic AI provider (OpenAI-compatible APIs, Groq, OpenRouter, etc.)
AI_PROVIDER=auto
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# YouTube upload automation
GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me
YOUTUBE_UPLOAD_REFRESH_TOKEN=replace_me
PRIVATE_VIDEO_TOKEN_SECRET=replace_with_a_long_random_secret
PRIVATE_VIDEO_TOKEN_TTL_SECONDS=900
PRIVATE_VIDEO_DELIVERY_URL_TTL_SECONDS=900
PRIVATE_VIDEO_DRM_ENABLED=false
PRIVATE_VIDEO_STORAGE_PROVIDER=local
COURSE_DEFAULT_VALIDITY_DAYS=183
ENABLE_VIDEO_TRANSCODING=true
SOURCE_PLAYBACK_FALLBACK_ENABLED=true
VIDEO_DELIVERY_PROFILE=cost-saver-hls
VIDEO_TARGET_RENDITIONS=480p,720p
VIDEO_HLS_SEGMENT_DURATION_SECONDS=6
VIDEO_KEEP_SOURCE_AFTER_PROCESSING=false
VIDEO_REPLAY_VIEW_LIMIT_ENABLED=false
VIDEO_REPLAY_MAX_VIEWS=0
VIDEO_REPLAY_RETENTION_DAYS=183
MAX_VIDEO_UPLOAD_MB=2048
VITE_MAX_VIDEO_UPLOAD_MB=2048

# Backend API / auth
MONGODB_URI=mongodb://127.0.0.1:27017/edumaster
POSTGRES_URL=postgresql://postgres@127.0.0.1:15432/edumaster
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=replace_with_a_long_random_secret
S3_BUCKET=replace_me
S3_REGION=ap-south-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
REPLAY_IMPORT_API_BASE_URL=http://127.0.0.1:5000/api
REPLAY_IMPORT_ADMIN_EMAIL=admin@example.com
REPLAY_IMPORT_ADMIN_PASSWORD=replace_me
REPLAY_IMPORT_DELETE_AFTER_SUCCESS=false
REPLAY_IMPORT_DURATION_MINUTES=60
LIVE_RECORDINGS_ROOT=
REPLAY_IMPORT_FILE_MIN_AGE_SECONDS=60
REPLAY_IMPORT_POLL_MS=15000

# Optional legacy TypeORM compatibility
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=edumaster

# Production recommendation for low-cost replay storage:
# PRIVATE_VIDEO_STORAGE_PROVIDER=s3
# Use any S3-compatible object storage such as Cloudflare R2, Backblaze B2 S3, Wasabi, MinIO, or AWS S3.
# Set S3_ENDPOINT when your provider is not AWS S3.
# Supabase: set POSTGRES_URL to the Supabase transaction or session pooler connection string.
# Upstash: set REDIS_URL to the provided rediss://default:<password>@<host>:6379 endpoint.
# Cloudflare R2: set S3_REGION=auto and S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com.
# LiveKit: set both VITE_LIVEKIT_URL and LIVEKIT_URL to your wss:// livekit endpoint for realtime classrooms.
# Managed HLS ingest: set LIVE_HLS_INTERNAL_BASE_URL, LIVE_INGEST_STREAM_BASE_URL, VITE_LIVE_HLS_BASE_URL, VITE_LIVE_INGEST_RTMP_URL, and LIVE_INGEST_PUBLISHER_SECRET together.

# Production safety flags
ALLOW_MEMORY_FALLBACK=false
EXPOSE_SAMPLE_CREDENTIALS=false

# Frontend-only live env mirrors
VITE_JITSI_MEET_DOMAIN=meet.jit.si

# Notes
# 1. The root dev server mounts the backend at /backend/api.
# 2. Postgres and Redis are optional in the current repo but are exposed through health/config for production wiring.
# 3. Firebase Hosting can rewrite /backend/* and /api/* traffic into a single serverless function.
