{$APP_DOMAIN} {
  encode gzip zstd

  handle /backend/api/courses/stream/* {
    reverse_proxy recorded-hls-cache:8080
  }

  handle /backend/api/courses/h/* {
    reverse_proxy recorded-hls-cache:8080
  }

  handle /backend/api/courses/hls/* {
    reverse_proxy recorded-hls-cache:8080
  }

  handle /backend/api/course-manifests/b/* {
    reverse_proxy recorded-hls-cache:8080
  }

  handle /backend/api/course-manifests/metrics {
    reverse_proxy manifest-app:5001 manifest-app-2:5001
  }

  handle /backend/api/course-manifests/health {
    reverse_proxy manifest-app:5001 manifest-app-2:5001
  }

  handle {
    reverse_proxy app:5000 app-2:5000
  }
}

{$LIVE_DOMAIN} {
  encode gzip zstd

  @hls_manifest path *.m3u8
  header @hls_manifest Cache-Control "public, max-age=2, stale-while-revalidate=6"

  @hls_segments path *.ts *.m4s *.mp4
  header @hls_segments Cache-Control "public, max-age=86400, immutable"

  reverse_proxy nginx-rtmp:8080
}
